{
  "description": "After Party named-worker lifecycle hooks.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir)\")/dispatcher/hooks/lifecycle.ts\"",
            "statusMessage": "Registering named After Party worker"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir)\")/dispatcher/hooks/lifecycle.ts\"",
            "statusMessage": "Recording After Party worker activity"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env node \"$(dirname \"$(git rev-parse --path-format=absolute --git-common-dir)\")/dispatcher/hooks/lifecycle.ts\"",
            "statusMessage": "Completing After Party worker activity"
          }
        ]
      }
    ]
  }
}
