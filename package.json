{
  "name": "after-party-labs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "party": "dispatcher/party.ts",
    "party-dispatcher": "dispatcher/cli.ts",
    "party-github-poller": "dispatcher/github-cli.ts"
  },
  "scripts": {
    "build:pages": "node scripts/build-pages.mjs --source site --output dist --commit local --base-path /after-party-labs/",
    "check:types": "tsc --noEmit",
    "dev": "node scripts/serve-pages.mjs",
    "party": "node dispatcher/party.ts",
    "party:queue": "node dispatcher/cli.ts",
    "poll:github": "node dispatcher/github-cli.ts",
    "test:dispatcher": "node --test test/dispatcher-*.test.ts",
    "test": "node --test"
  },
  "dependencies": {
    "@azure/msal-browser": "5.17.1"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2"
  }
}
