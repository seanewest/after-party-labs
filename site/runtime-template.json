            "expectedSubscriptionId": {
              "type": "string"
            },
            "applicationClientId": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "runtimeName": {
              "type": "string"
            },
            "commit": {
              "type": "string"
            },
            "apiImage": {
              "type": "string"
