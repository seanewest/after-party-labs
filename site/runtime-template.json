                    "enabled": true,
                    "registration": {
                      "clientId": "[parameters('applicationClientId')]",
                      "openIdIssuer": "[format('{0}{1}/v2.0', environment().authentication.loginEndpoint, parameters('expectedTenantId'))]"
                    },
                    "validation": {
                      "allowedAudiences": [
                        "[parameters('applicationClientId')]"
