    }
  },
  "parameters": {
    "expectedTenantId": {
      "type": "string",
      "metadata": {
        "description": "The tenant selected and verified by the signed-in operator."
      }
    },
    "expectedSubscriptionId": {
      "type": "string",
      "metadata": {
        "description": "The Azure subscription selected and verified by the signed-in operator."
      }
    },
    "applicationClientId": {
      "type": "string",
      "metadata": {
        "description": "The public multitenant After Party application that may call the runtime API."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "The Azure region validated for every runtime resource type."
      }
    },
    "resourceGroupName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 90,
      "metadata": {
        "description": "The resource group owned by this After Party runtime."
      }
    },
    "runtimeName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 30,
      "metadata": {
        "description": "A short lowercase name used for deterministic runtime resource names."
      }
    },
    "commit": {
      "type": "string",
      "minLength": 40,
      "maxLength": 40,
      "metadata": {
        "description": "The exact source commit deployed by this runtime."
      }
    },
    "apiImage": {
      "type": "string",
      "metadata": {
        "description": "A public API container image pinned to a sha256 digest."
      }
    }
  },
  "variables": {
    "imageParts": "[split(parameters('apiImage'), '@sha256:')]",
    "inputShapeMatches": "[and(and(equals(length(variables('imageParts')), 2), equals(length(last(variables('imageParts'))), 64)), equals(length(parameters('applicationClientId')), 36))]",
    "targetMatches": "[and(and(equals(subscription().subscriptionId, parameters('expectedSubscriptionId')), equals(tenant().tenantId, parameters('expectedTenantId'))), variables('inputShapeMatches'))]",
    "ownerRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '8e3af657-a8ff-443c-a75c-2fe8c4bcb635')]",
    "runtimeIdentityResourceId": "[format('{0}/providers/Microsoft.ManagedIdentity/userAssignedIdentities/{1}-identity', subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName')), parameters('runtimeName'))]"
  },
  "resources": [
    {
      "condition": "[variables('targetMatches')]",
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-11-01",
      "name": "[parameters('resourceGroupName')]",
      "location": "[parameters('location')]",
      "tags": {
        "after-party-managed": "true",
        "after-party-tenant-id": "[parameters('expectedTenantId')]",
        "after-party-subscription-id": "[parameters('expectedSubscriptionId')]",
        "after-party-commit": "[parameters('commit')]"
      }
    },
    {
      "condition": "[variables('targetMatches')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(subscription().id, variables('runtimeIdentityResourceId'), variables('ownerRoleDefinitionId'))]",
      "properties": {
        "description": "Broad After Party runtime authority for the isolated-lab exploration pass.",
        "principalId": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', format('{0}-runtime', parameters('runtimeName'))), '2025-04-01').outputs.identityPrincipalId.value]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[variables('ownerRoleDefinitionId')]"
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', format('{0}-runtime', parameters('runtimeName')))]",
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]"
      ]
    },
    {
      "condition": "[variables('targetMatches')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('{0}-runtime', parameters('runtimeName'))]",
      "resourceGroup": "[parameters('resourceGroupName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
