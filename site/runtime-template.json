            "value": "[parameters('applicationClientId')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "runtimeName": {
            "value": "[parameters('runtimeName')]"
          },
          "commit": {
            "value": "[parameters('commit')]"
          },
          "apiImage": {
            "value": "[parameters('apiImage')]"
          }
        },
