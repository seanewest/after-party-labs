              ]
            }
          ],
          "outputs": {
            "apiId": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/containerApps', variables('apiName'))]"
            },
            "apiUrl": {
              "type": "string",
              "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', variables('apiName')), '2025-01-01').configuration.ingress.fqdn)]"
