      "value": "[if(variables('targetMatches'), reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', format('{0}-runtime', parameters('runtimeName'))), '2025-04-01').outputs.tenantLockBlobPath.value, '')]"
