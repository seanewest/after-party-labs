      "value": "[if(variables('targetMatches'), subscriptionResourceId('Microsoft.Authorization/roleAssignments', guid(subscription().id, variables('runtimeIdentityResourceId'), variables('ownerRoleDefinitionId'))), '')]"
    },
    "stateContainerId": {
